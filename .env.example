# Engram Web Frontend Configuration

# API Endpoint
# Default: http://localhost:8800/api/v1
# Production: Use internal network hostname (e.g., http://engram:8800/api/v1)
VITE_ENGRAM_API_URL=http://localhost:8800/api/v1

# Feature Flags (optional)
# VITE_ENABLE_DEBUG=false

# Analytics (optional)
# VITE_ANALYTICS_ID=
